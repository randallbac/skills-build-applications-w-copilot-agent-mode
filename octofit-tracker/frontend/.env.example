# OctoFit Tracker – Frontend Environment Variables
#
# Copy this file to .env.local and fill in your values.
# VITE_CODESPACE_NAME must be set when running inside a GitHub Codespace.
# When unset, the app falls back to http://localhost:8000.
#
# Example:
#   VITE_CODESPACE_NAME=your-codespace-name
#
# The API base URL will be built as:
#   https://${VITE_CODESPACE_NAME}-8000.app.github.dev

# VITE_CODESPACE_NAME=
